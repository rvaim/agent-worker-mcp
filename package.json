{
  "name": "agent-worker-mcp",
  "version": "0.2.0",
  "description": "Generic MCP server for delegating tasks from one agent to another ACP-compatible worker agent through acpx.",
  "type": "module",
  "bin": {
    "agent-worker-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
